########################################################################
# .dockerignore – Excluye archivos innecesarios del build Docker
########################################################################

# Directorio target (resultados, clases compiladas)
target/

# Archivos de configuración del IDE
.vscode/
.idea/
.sonarlint/

# Allure local
.allure/

# Git
.git/
.gitignore

# Archivos de GitHub Actions (no necesarios dentro del contenedor)
.github/

# Logs
*.log

# Archivos temporales
*.tmp
*.bak
